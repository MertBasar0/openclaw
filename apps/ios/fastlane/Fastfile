require "shellwords"
require "open3"
require "json"
require "fileutils"

default_platform(:ios)

BETA_APP_IDENTIFIER = "com.mertbasar.ceviz"

def load_env_file(path)
  return unless File.exist?(path)

  File.foreach(path) do |line|
    stripped = line.strip
    next if stripped.empty? || stripped.start_with?("#")

    key, value = stripped.split("=", 2)
    next if key.nil? || key.empty? || value.nil?

    ENV[key] = value if ENV[key].nil? || ENV[key].strip.empty?
  end
end

def env_present?(value)
  !value.nil? && !value.strip.empty?
end

def clear_empty_env_var(key)
  return unless ENV.key?(key)
  ENV.delete(key) unless env_present?(ENV[key])
end

def maybe_decode_hex_keychain_secret(value)
  return value unless env_present?(value)

  candidate = value.strip
  return candidate unless candidate.match?(/\A[0-9a-fA-F]+\z/) && candidate.length.even?

  begin
    decoded = [candidate].pack("H*")
    return candidate unless decoded.valid_encoding?

    # `security find-generic-password -w` can return hex when the stored secret
    # includes newlines/non-printable bytes (like PEM files).
    beginPemMarker = %w[BEGIN PRIVATE KEY].join(" ") # pragma: allowlist secret
    endPemMarker = %w[END PRIVATE KEY].join(" ")
    if decoded.include?(beginPemMarker) || decoded.include?(endPemMarker)
      UI.message("Decoded hex-encoded ASC key content from Keychain.")
      return decoded
    end
  rescue StandardError
    return candidate
  end

  candidate
end

def read_asc_key_content_from_keychain
  service = ENV["ASC_KEYCHAIN_SERVICE"]
  service = "openclaw-asc-key" unless env_present?(service)

  account = ENV["ASC_KEYCHAIN_ACCOUNT"]
  account = ENV["USER"] unless env_present?(account)
  account = ENV["LOGNAME"] unless env_present?(account)
  return nil unless env_present?(account)

  begin
    stdout, _stderr, status = Open3.capture3(
      "security",
      "find-generic-password",
      "-s",
      service,
      "-a",
      account,
      "-w"
    )

    return nil unless status.success?

    key_content = stdout.to_s.strip
    key_content = maybe_decode_hex_keychain_secret(key_content)
    return nil unless env_present?(key_content)

    UI.message("Loaded ASC key content from Keychain service '#{service}' (account '#{account}').")
    key_content
  rescue Errno::ENOENT
    nil
  end
end

def repo_root
  File.expand_path("../../..", __dir__)
end

def ios_root
  File.expand_path("..", __dir__)
end

def read_ios_version_metadata
  script_path = File.join(repo_root, "scripts", "ios-version.ts")
  stdout, stderr, status = Open3.capture3(
    "node",
    "--import",
    "tsx",
    script_path,
    "--json",
    chdir: repo_root
  )

  unless status.success?
    detail = stderr.to_s.strip
    detail = stdout.to_s.strip if detail.empty?
    UI.user_error!("Failed to read iOS version metadata: #{detail}")
  end

  parsed = JSON.parse(stdout)
  version = parsed["canonicalVersion"].to_s.strip
  short_version = parsed["marketingVersion"].to_s.strip
  if !env_present?(version) || !env_present?(short_version)
    UI.user_error!("iOS version helper returned incomplete metadata.")
  end

  {
    short_version: short_version,
    version: version
  }
rescue JSON::ParserError => e
  UI.user_error!("Invalid JSON from iOS version helper: #{e.message}")
end

def sync_ios_versioning!
  script_path = File.join(repo_root, "scripts", "ios-sync-versioning.ts")
  stdout, stderr, status = Open3.capture3(
    "node",
    "--import",
    "tsx",
    script_path,
    "--check",
    chdir: repo_root
  )
  return if status.success?

  detail = stderr.to_s.strip
  detail = stdout.to_s.strip if detail.empty?
  UI.user_error!("iOS versioning artifacts are stale. Run `pnpm ios:version:sync`.\n#{detail}")
end

def shell_join(parts)
  Shellwords.join(parts.compact)
end

def xcodebuild_provisioning_arg_parts
  args = ["-allowProvisioningUpdates"]
  key_path = ENV["ASC_KEY_PATH"]
  key_id = ENV["ASC_KEY_ID"]
  issuer_id = ENV["ASC_ISSUER_ID"]
  return args if [key_path, key_id, issuer_id].any? { |v| !env_present?(v) }

  args.concat([
    "-authenticationKeyPath",
    File.expand_path(key_path),
    "-authenticationKeyID",
    key_id,
    "-authenticationKeyIssuerID",
    issuer_id
  ])
end

def xcodebuild_provisioning_args
  args = xcodebuild_provisioning_arg_parts
  shell_join(args)
end

def xcodebuild_archive_arg_parts
  args = xcodebuild_provisioning_arg_parts
  team_id = ENV["IOS_DEVELOPMENT_TEAM"]
  return args unless env_present?(team_id)

  args + ["DEVELOPMENT_TEAM=#{team_id}", "OPENCLAW_DEVELOPMENT_TEAM=#{team_id}"]
end

def resolve_beta_build_number(api_key:, short_version:)
  explicit = ENV["IOS_BETA_BUILD_NUMBER"]
  if env_present?(explicit)
    UI.user_error!("Invalid IOS_BETA_BUILD_NUMBER '#{explicit}'. Expected digits only.") unless explicit.match?(/\A\d+\z/)
    UI.message("Using explicit iOS beta build number #{explicit}.")
    return explicit
  end

  latest_build = latest_testflight_build_number(
    api_key: api_key,
    app_identifier: BETA_APP_IDENTIFIER,
    version: short_version,
    initial_build_number: 0
  )
  next_build = latest_build.to_i + 1
  UI.message("Resolved iOS beta build number #{next_build} for #{short_version} (latest TestFlight build: #{latest_build}).")
  next_build.to_s
end

def beta_build_number_needs_asc_auth?
  explicit = ENV["IOS_BETA_BUILD_NUMBER"]
  !env_present?(explicit)
end

def prepare_beta_release!(version:, build_number:)
  script_path = File.join(repo_root, "scripts", "ios-beta-prepare.sh")
  UI.message("Preparing iOS beta release #{version} (build #{build_number}).")
  sh(shell_join(["bash", script_path, "--build-number", build_number]))

  beta_xcconfig = File.join(ios_root, "build", "BetaRelease.xcconfig")
  UI.user_error!("Missing beta xcconfig at #{beta_xcconfig}.") unless File.exist?(beta_xcconfig)

  ENV["XCODE_XCCONFIG_FILE"] = beta_xcconfig
  beta_xcconfig
end

def fetch_or_create_profile(api_key:, app_id:)
  get_provisioning_profile(
    api_key: api_key,
    app_identifier: app_id,
    readonly: false,
    output_path: "build/profiles"
  )
  lane_context[SharedValues::SIGH_PROFILE_PATH]
end

def provision_all_targets(api_key:)
  bundle_ids = {
    "com.mertbasar.ceviz" => nil,
    "com.mertbasar.ceviz.share" => nil,
    "com.mertbasar.ceviz.watchkitapp" => nil,
    "com.mertbasar.ceviz.watchkitapp.extension" => nil,
    "com.mertbasar.ceviz.activitywidget" => nil
  }

  profiles = {}
  bundle_ids.each_key do |bid|
    UI.message("Provisioning #{bid}...")
    fetch_or_create_profile(api_key: api_key, app_id: bid)
    name = lane_context[SharedValues::SIGH_NAME]
    profiles[bid] = name
    UI.success("Profile for #{bid}: #{name}")
  end
  profiles
end

def testflight_public_group_name
  name = ENV["IOS_TESTFLIGHT_PUBLIC_GROUP_NAME"]
  return name.strip if env_present?(name)

  "Ceviz Public Beta"
end

def testflight_public_link_limit
  raw = ENV["IOS_TESTFLIGHT_PUBLIC_LINK_LIMIT"]
  return 10_000 unless env_present?(raw)

  UI.user_error!("Invalid IOS_TESTFLIGHT_PUBLIC_LINK_LIMIT '#{raw}'. Expected digits only.") unless raw.match?(/\A\d+\z/)
  raw.to_i
end

def testflight_beta_description
  description = ENV["IOS_TESTFLIGHT_BETA_DESCRIPTION"]
  return description.strip if env_present?(description)

  "Ceviz brings OpenClaw approvals, triage, and status updates to iPhone and Apple Watch for private beta testing."
end

def ensure_testflight_beta_app_description!(app:)
  locale = ENV["IOS_TESTFLIGHT_BETA_LOCALE"]
  locale = "en-US" unless env_present?(locale)

  attributes = {
    description: testflight_beta_description
  }
  feedback_email = ENV["IOS_TESTFLIGHT_FEEDBACK_EMAIL"]
  attributes[:feedbackEmail] = feedback_email.strip if env_present?(feedback_email)

  localization = app.get_beta_app_localizations.find { |entry| entry.locale == locale }
  if localization.nil?
    UI.message("Creating TestFlight beta app description for #{locale}.")
    Spaceship::ConnectAPI.post_beta_app_localizations(
      app_id: app.id,
      attributes: attributes.merge(locale: locale)
    )
  elsif !env_present?(localization.description)
    UI.message("Updating TestFlight beta app description for #{locale}.")
    Spaceship::ConnectAPI.patch_beta_app_localizations(
      localization_id: localization.id,
      attributes: attributes
    )
  else
    UI.message("TestFlight beta app description already exists for #{locale}.")
  end
end

def ensure_testflight_public_group!(app:, group_name:, link_limit:)
  group = app.get_beta_groups.find { |candidate| candidate.name == group_name }

  if group.nil?
    UI.message("Creating TestFlight public beta group '#{group_name}'.")
    group = app.create_beta_group(
      group_name: group_name,
      public_link_enabled: true,
      public_link_limit: link_limit,
      public_link_limit_enabled: true
    )
  else
    UI.message("Using existing TestFlight public beta group '#{group_name}'.")
    group = group.update(
      attributes: {
        public_link_enabled: true,
        public_link_limit: link_limit,
        public_link_limit_enabled: true
      }
    ) || group
  end

  group
end

def latest_attachable_testflight_build(app:)
  builds = app.get_builds(
    includes: Spaceship::ConnectAPI::Build::ESSENTIAL_INCLUDES,
    sort: "-uploadedDate",
    limit: 20
  )

  builds.find do |build|
    !build.expired &&
      build.processing_state == "VALID" &&
      build.build_beta_detail &&
      build.build_beta_detail.external_build_state != "PROCESSING"
  end
end

def refresh_testflight_group(app:, group_id:)
  app.get_beta_groups.find { |candidate| candidate.id == group_id }
end

def submit_testflight_beta_review_if_ready!(build:)
  return if build.nil? || build.build_beta_detail.nil?

  external_state = build.build_beta_detail.external_build_state
  return unless external_state == "READY_FOR_BETA_SUBMISSION"

  UI.message("Submitting TestFlight build #{build.app_version} (#{build.version}) for external beta review.")
  begin
    build.post_beta_app_review_submission
  rescue Spaceship::UnexpectedResponse => e
    if e.message.include?("Beta Contract") || e.message.include?("contract")
      UI.important("Beta review submission failed: #{e.message}")
      UI.important("Accept the pending agreement at https://appstoreconnect.apple.com/agreements then retry.")
    else
      raise
    end
  end
end

def ensure_testflight_public_invite!
  asc_api_key

  app = Spaceship::ConnectAPI::App.find(BETA_APP_IDENTIFIER)
  UI.user_error!("App Store Connect app not found for #{BETA_APP_IDENTIFIER}.") if app.nil?

  ensure_testflight_beta_app_description!(app: app)

  group_name = testflight_public_group_name
  group = ensure_testflight_public_group!(
    app: app,
    group_name: group_name,
    link_limit: testflight_public_link_limit
  )

  build = latest_attachable_testflight_build(app: app)
  if build.nil?
    UI.important("No processed TestFlight build is ready to attach to '#{group_name}' yet.")
  else
    UI.message(
      "Attaching latest TestFlight build #{build.app_version} (#{build.version}); externalState=#{build.build_beta_detail.external_build_state}."
    )
    build.add_beta_groups(beta_groups: [group])
    submit_testflight_beta_review_if_ready!(build: build)
  end

  group = refresh_testflight_group(app: app, group_id: group.id) || group
  public_link = group.public_link
  public_link_id = group.public_link_id

  UI.success("TestFlight public group: #{group.name}")
  UI.success("TestFlight public link: #{public_link}") if env_present?(public_link)
  UI.success("TestFlight public link id: #{public_link_id}") if env_present?(public_link_id)

  output_path = ENV["IOS_TESTFLIGHT_INVITE_OUTPUT"]
  if env_present?(output_path)
    output_path = File.expand_path(output_path, ios_root) unless output_path.start_with?("/")
    FileUtils.mkdir_p(File.dirname(output_path))
    File.write(
      output_path,
      JSON.pretty_generate(
        {
          appIdentifier: BETA_APP_IDENTIFIER,
          groupId: group.id,
          groupName: group.name,
          publicLink: public_link,
          publicLinkId: public_link_id,
          attachedBuildId: build&.id,
          attachedBuildVersion: build&.app_version,
          attachedBuildNumber: build&.version,
          externalBuildState: build&.build_beta_detail&.external_build_state
        }
      )
    )
  end

  UI.user_error!("TestFlight public invite code was not returned by App Store Connect yet.") unless env_present?(public_link_id)

  {
    public_link: public_link,
    public_link_id: public_link_id
  }
end

def build_beta_release(context)
  version = context[:version]
  output_directory = File.join("build", "beta")
  archive_path = File.join(output_directory, "OpenClaw-#{version}.xcarchive")
  archive_xcargs = shell_join(xcodebuild_archive_arg_parts)

  # Fetch/create provisioning profiles for all targets
  profiles = provision_all_targets(api_key: context[:api_key])

  build_app(
    project: "OpenClaw.xcodeproj",
    scheme: "OpenClaw",
    configuration: "Release",
    export_method: "app-store",
    clean: true,
    skip_profile_detection: true,
    build_path: "build",
    archive_path: archive_path,
    output_directory: output_directory,
    output_name: "OpenClaw-#{version}.ipa",
    xcargs: archive_xcargs,
    export_options: {
      signingStyle: "manual",
      teamID: ENV["IOS_DEVELOPMENT_TEAM"],
      provisioningProfiles: profiles
    }
  )

  {
    archive_path: archive_path,
    build_number: context[:build_number],
    ipa_path: lane_context[SharedValues::IPA_OUTPUT_PATH],
    short_version: context[:short_version],
    version: version
  }
end

platform :ios do
  private_lane :asc_api_key do
    load_env_file(File.join(__dir__, ".env"))
    clear_empty_env_var("APP_STORE_CONNECT_API_KEY_PATH")
    clear_empty_env_var("ASC_KEY_PATH")
    clear_empty_env_var("ASC_KEY_CONTENT")

    api_key = nil

    key_path = ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    if env_present?(key_path)
      api_key = app_store_connect_api_key(path: key_path)
    else
      p8_path = ENV["ASC_KEY_PATH"]
      if env_present?(p8_path)
        key_id = ENV["ASC_KEY_ID"]
        issuer_id = ENV["ASC_ISSUER_ID"]
        UI.user_error!("Missing ASC_KEY_ID or ASC_ISSUER_ID for ASC_KEY_PATH auth.") if [key_id, issuer_id].any? { |v| !env_present?(v) }

        api_key = app_store_connect_api_key(
          key_id: key_id,
          issuer_id: issuer_id,
          key_filepath: p8_path
        )
      else
        key_id = ENV["ASC_KEY_ID"]
        issuer_id = ENV["ASC_ISSUER_ID"]
        key_content = ENV["ASC_KEY_CONTENT"]
        key_content = read_asc_key_content_from_keychain unless env_present?(key_content)

        UI.user_error!(
          "Missing App Store Connect API key. Set APP_STORE_CONNECT_API_KEY_PATH (json), ASC_KEY_PATH (p8), or ASC_KEY_ID/ASC_ISSUER_ID with ASC_KEY_CONTENT (or Keychain via ASC_KEYCHAIN_SERVICE/ASC_KEYCHAIN_ACCOUNT)."
        ) if [key_id, issuer_id, key_content].any? { |v| !env_present?(v) }

        is_base64 = key_content.include?("BEGIN PRIVATE KEY") ? false : true

        api_key = app_store_connect_api_key(
          key_id: key_id,
          issuer_id: issuer_id,
          key_content: key_content,
          is_key_content_base64: is_base64
        )
      end
    end

    api_key
  end

  private_lane :prepare_beta_context do |options|
    require_api_key = options[:require_api_key] == true
    needs_api_key = require_api_key || beta_build_number_needs_asc_auth?
    api_key = needs_api_key ? asc_api_key : nil
    sync_ios_versioning!
    version_metadata = read_ios_version_metadata
    version = version_metadata[:version]
    short_version = version_metadata[:short_version]
    build_number = resolve_beta_build_number(api_key: api_key, short_version: short_version)
    beta_xcconfig = prepare_beta_release!(version: version, build_number: build_number)

    {
      api_key: api_key,
      beta_xcconfig: beta_xcconfig,
      build_number: build_number,
      short_version: short_version,
      version: version
    }
  end

  desc "Build a beta archive locally without uploading"
  lane :beta_archive do
    context = prepare_beta_context(require_api_key: false)
    build = build_beta_release(context)
    UI.success("Built iOS beta archive: version=#{build[:version]} short=#{build[:short_version]} build=#{build[:build_number]}")
    build
  ensure
    ENV.delete("XCODE_XCCONFIG_FILE")
  end

  desc "Build + upload a beta to TestFlight"
  lane :beta do
    context = prepare_beta_context(require_api_key: true)
    build = build_beta_release(context)

    upload_to_testflight(
      api_key: context[:api_key],
      ipa: build[:ipa_path],
      skip_waiting_for_build_processing: true,
      uses_non_exempt_encryption: false
    )

    UI.success("Uploaded iOS beta: version=#{build[:version]} short=#{build[:short_version]} build=#{build[:build_number]}")
  ensure
    ENV.delete("XCODE_XCCONFIG_FILE")
  end

  desc "Create or refresh the Ceviz TestFlight public invite link"
  lane :testflight_invite do
    ensure_testflight_public_invite!
  end

  desc "Upload App Store metadata (and optionally screenshots)"
  lane :metadata do
    sync_ios_versioning!
    api_key = asc_api_key
    clear_empty_env_var("APP_STORE_CONNECT_API_KEY_PATH")
    app_identifier = ENV["ASC_APP_IDENTIFIER"]
    app_id = ENV["ASC_APP_ID"]
    app_identifier = nil unless env_present?(app_identifier)
    app_id = nil unless env_present?(app_id)

    deliver_options = {
      api_key: api_key,
      force: true,
      skip_screenshots: ENV["DELIVER_SCREENSHOTS"] != "1",
      skip_metadata: ENV["DELIVER_METADATA"] != "1",
      run_precheck_before_submit: false
    }
    deliver_options[:app_identifier] = app_identifier if app_identifier
    if app_id && app_identifier.nil?
      # `deliver` prefers app_identifier from Appfile unless explicitly blanked.
      deliver_options[:app_identifier] = ""
      deliver_options[:app] = app_id
    end

    deliver(**deliver_options)
  end

  desc "Validate App Store Connect API auth"
  lane :auth_check do
    asc_api_key
    UI.success("App Store Connect API auth loaded successfully.")
  end

  desc "Ensure internal TestFlight group + tester + latest build (no beta review needed)"
  lane :internal_test do
    asc_api_key

    email = ENV["IOS_INTERNAL_TESTER_EMAIL"]
    UI.user_error!("IOS_INTERNAL_TESTER_EMAIL is required") unless env_present?(email)
    group_name = env_present?(ENV["IOS_INTERNAL_GROUP_NAME"]) ? ENV["IOS_INTERNAL_GROUP_NAME"] : "Internal"

    app = Spaceship::ConnectAPI::App.find(BETA_APP_IDENTIFIER)
    UI.user_error!("App Store Connect app not found for #{BETA_APP_IDENTIFIER}.") if app.nil?

    groups = app.get_beta_groups(includes: "betaTesters")
    UI.message("=== Existing beta groups ===")
    groups.each do |g|
      testers = (g.get_beta_testers rescue [])
      emails = testers.map { |t| (t.email rescue nil) }.compact
      UI.message("  - name=#{g.name.inspect} id=#{g.id} internal=#{g.is_internal_group.inspect} publicLink=#{g.public_link.inspect} testers=#{emails.inspect}")
    end

    internal = groups.find { |g| g.is_internal_group == true && g.name == group_name } ||
               groups.find { |g| g.is_internal_group == true }
    if internal.nil?
      UI.message("No internal group found; creating internal group '#{group_name}'.")
      internal = app.create_beta_group(group_name: group_name, is_internal_group: true)
    else
      UI.message("Using existing internal group: #{internal.name} (#{internal.id})")
    end

    # Internal groups automatically include all processed builds; no per-build assignment needed.
    build = latest_attachable_testflight_build(app: app)
    UI.message("Latest build: #{build&.app_version} (#{build&.version}) internalState=#{build&.build_beta_detail&.internal_build_state}")

    # Who are the App Store Connect users? Internal testers MUST be team users.
    begin
      users = Spaceship::ConnectAPI::User.all
      UI.message("=== ASC Users (#{users.size}) ===")
      users.each do |u|
        uname = (u.username rescue nil)
        uemail = (u.email rescue nil)
        attrs = (u.instance_variable_get(:@attributes) rescue nil) || (u.to_h rescue nil)
        UI.message("  - username=#{uname.inspect} email=#{uemail.inspect} name=#{(u.first_name rescue '')} #{(u.last_name rescue '')} roles=#{(u.roles rescue []).inspect}")
        UI.message("    raw attrs keys=#{(attrs.is_a?(Hash) ? attrs.keys : attrs).inspect}")
        UI.message("    raw attrs=#{attrs.inspect}")
      end
      match = users.find { |u| [ (u.username rescue nil), (u.email rescue nil) ].compact.map { |x| x.to_s.downcase }.include?(email.downcase) }
      UI.message("Requested tester #{email} is an ASC user? #{!match.nil?}")
    rescue => e
      UI.important("User.all error: #{e.class} #{e.message}")
    end

    current = (internal.get_beta_testers rescue [])
    already = current.any? { |t| ((t.email rescue "") || "").downcase == email.downcase }
    if already
      UI.success("Tester #{email} already present in internal group.")
    else
      UI.message("Adding internal tester #{email} ...")
      added = false
      attempts = [
        ["create+assign via post_beta_tester_assignment", lambda {
          Spaceship::ConnectAPI.post_beta_tester_assignment(
            beta_group_ids: [internal.id],
            attributes: { firstName: "Mert", lastName: "Basar", email: email }
          )
        }],
        ["existing tester -> add_beta_tester_to_group", lambda {
          existing = (Spaceship::ConnectAPI.get_beta_testers(filter: { email: email }) rescue [])
          tester = existing.find { |t| ((t.email rescue "") || "").downcase == email.downcase } || existing.first
          raise "no existing beta tester for #{email}" if tester.nil?
          Spaceship::ConnectAPI.add_beta_tester_to_group(beta_group_id: internal.id, beta_tester_ids: [tester.id])
        }],
      ]
      attempts.each do |label, fn|
        next if added
        begin
          fn.call
          added = true
          UI.success("added via #{label}")
        rescue => e
          UI.important("#{label} failed: #{e.class} #{e.message}")
        end
      end
      UI.success("Tester add attempted (success=#{added}).")
    end

    final = app.get_beta_groups(includes: "betaTesters").find { |g| g.id == internal.id } || internal
    final_testers = (final.get_beta_testers rescue [])
    UI.success("=== FINAL ===")
    UI.success("group=#{final.name} id=#{final.id} internal=#{final.is_internal_group.inspect}")
    UI.success("testers=#{final_testers.map { |t| (t.email rescue nil) }.compact.inspect}")
    UI.success("attachedBuild=#{build&.app_version} (#{build&.version})")

    # --- Certificate audit / revoke (to free the signing certificate cap) ---
    begin
      certs = Spaceship::ConnectAPI::Certificate.all
      UI.success("=== Certificates (#{certs.size}) ===")
      certs.each do |c|
        UI.success("  - id=#{c.id} type=#{(c.certificate_type rescue '?')} name=#{(c.display_name rescue (c.name rescue '?')).inspect} serial=#{(c.serial_number rescue '?')} expires=#{(c.expiration_date rescue '?')}")
      end

      revoke_ids = (ENV["IOS_REVOKE_CERT_IDS"] || "").split(",").map(&:strip).reject(&:empty?)
      unless revoke_ids.empty?
        UI.important("Revoking cert ids: #{revoke_ids.inspect}")
        revoke_ids.each do |rid|
          target = certs.find { |c| c.id == rid }
          if target.nil?
            UI.important("  cert #{rid} not found; skipping")
            next
          end
          begin
            target.delete!
            UI.success("  revoked #{rid} (#{(target.certificate_type rescue '?')})")
          rescue => e
            UI.important("  revoke #{rid} failed: #{e.class} #{e.message}")
          end
        end
        remaining = Spaceship::ConnectAPI::Certificate.all
        UI.success("=== Certificates after revoke (#{remaining.size}) ===")
        remaining.each { |c| UI.success("  - id=#{c.id} type=#{(c.certificate_type rescue '?')}") }
      end
    rescue => e
      UI.important("cert audit/revoke error: #{e.class} #{e.message}")
    end
  end
end
